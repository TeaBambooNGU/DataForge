# OpenAI-compatible relay configuration
# Fill these values, then copy the same keys into `.env`.

OPENAI_BASE_URL=https://your-relay.example.com/v1
OPENAI_API_KEY=sk-your-relay-key

# Anthropic-compatible relay configuration
# Use these keys when `provider: anthropic_compatible`.

ANTHROPIC_BASE_URL=https://your-anthropic-relay.example.com/v1
ANTHROPIC_API_KEY=sk-ant-your-relay-key

# MiniMax configuration
# `provider: minimax` is an Anthropic-compatible shortcut with MiniMax env defaults.

MINIMAX_BASE_URL=https://your-minimax-relay.example.com/v1
MINIMAX_API_KEY=sk-minimax-your-key

# Optional overrides if your relay uses separate endpoints or keys.
# GENERATOR_OPENAI_BASE_URL=https://your-relay.example.com/v1
# GENERATOR_OPENAI_API_KEY=sk-your-generator-key
# TEACHER_OPENAI_BASE_URL=https://your-relay.example.com/v1
# TEACHER_OPENAI_API_KEY=sk-your-teacher-key
